APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=sail
# DB_PASSWORD=password

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Phải > job chạy lâu nhất (vd. ProcessDeviceOperation 420s) — nếu nhỏ hơn, database driver có thể nhả job ra chạy trùng.
DB_QUEUE_RETRY_AFTER=480

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
# Docker/Sail: `redis` | chạy PHP trên máy: 127.0.0.1
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
# DB 0 = default/queue; cache dùng connection `cache` (mặc định DB 1) trong config/database.php

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Inertia SSR — `true`: render HTML lần đầu qua Node.
# • Local: chạy `npm run dev` (Vite có `/__inertia_ssr`; Laravel dùng hot URL, không cần `inertia:start-ssr`).
# • Production: `npm run build:ssr` rồi `php artisan inertia:start-ssr` (URL mặc định dưới).
INERTIA_SSR_ENABLED=false
INERTIA_SSR_URL=http://127.0.0.1:13714
# Không SSR các path (phân tách bằng dấu phẩy), vd. dashboard — dùng khi một trang làm Node/CF 502.
# INERTIA_SSR_EXCLUDE_PATHS=dashboard

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

BANK_LOOKUP_API_KEY=
BANK_LOOKUP_API_SECRET_KEY=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

OCTANE_SERVER=roadrunner
OCTANE_HTTPS=false
